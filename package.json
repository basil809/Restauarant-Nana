{
  "name": "nana-swahili-restaurant",
  "version": "1.0.0",
  "description": "Premium Swahili Fine Dining Restaurant Website",
  "main": "backend/server.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "nodemon backend/server.js",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "node backend/server.js",
    "seed": "node backend/scripts/seed.js"
  },
  "keywords": [
    "restaurant",
    "swahili",
    "fine-dining",
    "nairobi"
  ],
  "author": "Nana Swahili Restaurant",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "nodemailer": "^6.9.5",
    "axios": "^1.5.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.1"
  }
}
